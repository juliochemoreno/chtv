{
  "name": "chtv",
  "version": "0.1.0",
  "private": true,
  "description": "CHTV — Live broadcast deck for HLS/M3U streaming with EPG and Chromecast support.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply tv-stream --local",
    "db:migrate:remote": "wrangler d1 migrations apply tv-stream --remote",
    "db:seed:local": "wrangler d1 execute tv-stream --local --file=migrations/0001_init.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.6.14",
    "lucide-react": "^1.12.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^0.1.10",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wrangler": "^3.101.0"
  }
}
